#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
PIDOCKER_IMAGE="${PIDOCKER_IMAGE:-pidocker:local}"
PIDOCKER_DOCKER_CONTEXT="${PIDOCKER_DOCKER_CONTEXT:-${REPO_ROOT}/docker}"
PIDOCKER_VOLUME_PREFIX="${PIDOCKER_VOLUME_PREFIX:-pidocker}"
PIDOCKER_HOME_VOLUME="${PIDOCKER_VOLUME_PREFIX}-home"
PIDOCKER_WORKSPACE_VOLUME="${PIDOCKER_VOLUME_PREFIX}-workspace"

show_help() {
  cat <<'HELP'
pidocker - run Pi inside a Docker container

Usage:
  pidocker [--help]
  pidocker [REPO|GIT_URL]
  pidocker setupssh
  pidocker secrets set KEY
  pidocker completion bash|zsh

Commands:
  setupssh              Create/show the dedicated pidocker SSH public key
  secrets set KEY       Read a secret value securely and store it in pidocker-home
  completion bash|zsh   Print shell completion for repository names

Arguments:
  REPO      Start Pi in /workspace/repos/REPO
  GIT_URL   Clone the repository into /workspace/repos, then start Pi there

Options:
  -h, --help    Show this help message and exit
HELP
}

ensure_docker_available() {
  if ! command -v docker >/dev/null 2>&1; then
    echo "pidocker: docker command not found" >&2
    exit 127
  fi
}

ensure_image_exists() {
  if docker image inspect "${PIDOCKER_IMAGE}" >/dev/null 2>&1; then
    return 0
  fi

  docker build -t "${PIDOCKER_IMAGE}" "${PIDOCKER_DOCKER_CONTEXT}"
}

run_container() {
  local repo_arg="${1:-}"

  ensure_docker_available
  ensure_image_exists

  exec docker run \
    --rm \
    -it \
    --label app=pidocker \
    --env "PIDOCKER_REPO_ARG=${repo_arg}" \
    --mount "type=volume,source=${PIDOCKER_HOME_VOLUME},target=/home/pi" \
    --mount "type=volume,source=${PIDOCKER_WORKSPACE_VOLUME},target=/workspace" \
    "${PIDOCKER_IMAGE}" \
    bash -lc '
      set -euo pipefail
      settings_file=/home/pi/.pi/agent/settings.json
      mkdir -p /home/pi/.pi/agent
      PI_SETTINGS_FILE="${settings_file}" node <<"NODE"
const fs = require("fs");
const settingsFile = process.env.PI_SETTINGS_FILE;
let settings = {};
try {
  settings = JSON.parse(fs.readFileSync(settingsFile, "utf8"));
} catch (_) {}
if (!Array.isArray(settings.packages)) settings.packages = [];
if (!settings.packages.includes("npm:pi-web-access")) {
  settings.packages.push("npm:pi-web-access");
}
fs.writeFileSync(settingsFile, `${JSON.stringify(settings, null, 2)}\n`);
NODE

      secrets_file=/home/pi/.pidocker/secrets/env
      if [ -f "${secrets_file}" ]; then
        while IFS="=" read -r key value; do
          if [ -n "${key}" ] && [[ "${key}" =~ ^[A-Z_][A-Z0-9_]*$ ]]; then
            export "${key}=${value}"
          fi
        done < "${secrets_file}"
      fi
      repo_arg="${PIDOCKER_REPO_ARG:-}"
      workdir=/workspace/repos
      if [ -n "${repo_arg}" ]; then
        case "${repo_arg}" in
          *://*|git@*|ssh://*|*.git)
            repo_name="${repo_arg##*/}"
            repo_name="${repo_name%.git}"
            if [ -z "${repo_name}" ] || [ "${repo_name}" = ".." ] || [[ "${repo_name}" = */* ]]; then
              echo "pidocker: could not derive repository name from URL: ${repo_arg}" >&2
              exit 2
            fi
            workdir="/workspace/repos/${repo_name}"
            if [ ! -d "${workdir}/.git" ]; then
              mkdir -p /workspace/repos
              git clone "${repo_arg}" "${workdir}"
            fi
            ;;
          */*|.*|*..*)
            echo "pidocker: repository name must be a direct child of /workspace/repos" >&2
            exit 2
            ;;
          *)
            workdir="/workspace/repos/${repo_arg}"
            if [ ! -d "${workdir}" ]; then
              echo "pidocker: repository not found: ${workdir}" >&2
              echo "pidocker: available repositories:" >&2
              find /workspace/repos -mindepth 1 -maxdepth 1 -type d -printf "  %f\n" 2>/dev/null | sort >&2 || true
              exit 2
            fi
            ;;
        esac
      fi
      cd "${workdir}"
      exec pi
    '
}

setup_ssh() {
  ensure_docker_available
  ensure_image_exists

  exec docker run \
    --rm \
    --label app=pidocker \
    --mount "type=volume,source=${PIDOCKER_HOME_VOLUME},target=/home/pi" \
    --mount "type=volume,source=${PIDOCKER_WORKSPACE_VOLUME},target=/workspace" \
    "${PIDOCKER_IMAGE}" \
    pidocker-ssh-setup
}

show_completion() {
  local shell="${1:-}"
  case "${shell}" in
    bash)
      cat <<'BASH'
_pidocker_complete() {
  local cur="${COMP_WORDS[COMP_CWORD]}"
  if [[ ${COMP_CWORD} -eq 1 ]]; then
    local commands="setupssh secrets completion --help -h"
    local repos
    repos=$(docker run --rm --mount "type=volume,source=${PIDOCKER_VOLUME_PREFIX:-pidocker}-workspace,target=/workspace" "${PIDOCKER_IMAGE:-pidocker:local}" bash -lc 'find /workspace/repos -mindepth 1 -maxdepth 1 -type d -printf "%f\n" 2>/dev/null' 2>/dev/null || true)
    COMPREPLY=( $(compgen -W "${commands} ${repos}" -- "${cur}") )
  fi
}
complete -F _pidocker_complete pidocker
BASH
      ;;
    zsh)
      cat <<'ZSH'
#compdef pidocker
_pidocker() {
  local -a repos commands
  commands=(setupssh secrets completion --help -h)
  repos=(${(f)"$(docker run --rm --mount "type=volume,source=${PIDOCKER_VOLUME_PREFIX:-pidocker}-workspace,target=/workspace" "${PIDOCKER_IMAGE:-pidocker:local}" bash -lc 'find /workspace/repos -mindepth 1 -maxdepth 1 -type d -printf "%f\n" 2>/dev/null' 2>/dev/null)"})
  _describe 'pidocker arguments' commands repos
}
_pidocker "$@"
ZSH
      ;;
    *)
      echo "Usage: pidocker completion bash|zsh" >&2
      exit 2
      ;;
  esac
}

set_secret() {
  local key="${1:-}"
  if [[ -z "${key}" || $# -ne 1 ]]; then
    echo "Usage: pidocker secrets set KEY" >&2
    exit 2
  fi
  if [[ ! "${key}" =~ ^[A-Z_][A-Z0-9_]*$ ]]; then
    echo "pidocker: secret key must match [A-Z_][A-Z0-9_]*" >&2
    exit 2
  fi

  ensure_docker_available
  ensure_image_exists

  local value
  if [[ -t 0 ]]; then
    printf "Value for %s: " "${key}" >&2
    IFS= read -r -s value
    printf "\n" >&2
  else
    IFS= read -r value
  fi
  if [[ -z "${value}" ]]; then
    echo "pidocker: secret value must not be empty" >&2
    exit 2
  fi

  printf '%s' "${value}" | docker run \
    --rm \
    -i \
    --label app=pidocker \
    --env "PIDOCKER_SECRET_KEY=${key}" \
    --mount "type=volume,source=${PIDOCKER_HOME_VOLUME},target=/home/pi" \
    --mount "type=volume,source=${PIDOCKER_WORKSPACE_VOLUME},target=/workspace" \
    "${PIDOCKER_IMAGE}" \
    bash -lc '
      set -euo pipefail
      key="${PIDOCKER_SECRET_KEY}"
      value="$(cat)"
      umask 077
      mkdir -p /home/pi/.pidocker/secrets
      secrets_file=/home/pi/.pidocker/secrets/env
      tmp_file="$(mktemp)"
      if [ -f "${secrets_file}" ]; then
        grep -v -E "^${key}=" "${secrets_file}" > "${tmp_file}" || true
      fi
      printf "%s=%s\n" "${key}" "${value}" >> "${tmp_file}"
      mv "${tmp_file}" "${secrets_file}"
      chmod 600 "${secrets_file}"
      if [ "${key}" = "NOTION_API_KEY" ]; then
        printf "%s=%s\n" "${key}" "${value}" > /home/pi/.pidocker/secrets/notion.env
        chmod 600 /home/pi/.pidocker/secrets/notion.env
      fi
    '
  echo "Stored secret ${key} in pidocker-home."
}

case "${1:-}" in
  -h|--help)
    show_help
    exit 0
    ;;
  "")
    run_container
    ;;
  setupssh)
    setup_ssh
    ;;
  secrets)
    if [[ "${2:-}" != "set" || -z "${3:-}" || -n "${4:-}" ]]; then
      echo "Usage: pidocker secrets set KEY" >&2
      exit 2
    fi
    set_secret "${3}"
    ;;
  completion)
    if [[ -z "${2:-}" || -n "${3:-}" ]]; then
      echo "Usage: pidocker completion bash|zsh" >&2
      exit 2
    fi
    show_completion "${2}"
    ;;
  -* )
    echo "Unknown option: $1" >&2
    show_help >&2
    exit 2
    ;;
  *)
    if [[ -n "${2:-}" ]]; then
      echo "Usage: pidocker [REPO|GIT_URL]" >&2
      exit 2
    fi
    run_container "${1}"
    ;;
esac
