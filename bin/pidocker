#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
PIDOCKER_IMAGE="${PIDOCKER_IMAGE:-pidocker:local}"
PIDOCKER_DOCKER_CONTEXT="${PIDOCKER_DOCKER_CONTEXT:-${REPO_ROOT}/docker}"
PIDOCKER_VOLUME_PREFIX="${PIDOCKER_VOLUME_PREFIX:-pidocker}"
PIDOCKER_HOME_VOLUME="${PIDOCKER_VOLUME_PREFIX}-home"
PIDOCKER_WORKSPACE_VOLUME="${PIDOCKER_VOLUME_PREFIX}-workspace"

show_help() {
  cat <<'HELP'
pidocker - run Pi inside a Docker container

Usage:
  pidocker [--help]
  pidocker

Options:
  -h, --help    Show this help message and exit
HELP
}

ensure_docker_available() {
  if ! command -v docker >/dev/null 2>&1; then
    echo "pidocker: docker command not found" >&2
    exit 127
  fi
}

ensure_image_exists() {
  if docker image inspect "${PIDOCKER_IMAGE}" >/dev/null 2>&1; then
    return 0
  fi

  docker build -t "${PIDOCKER_IMAGE}" "${PIDOCKER_DOCKER_CONTEXT}"
}

run_container() {
  ensure_docker_available
  ensure_image_exists

  exec docker run \
    --rm \
    -it \
    --label app=pidocker \
    --volume "${PIDOCKER_HOME_VOLUME}:/home/pi" \
    --volume "${PIDOCKER_WORKSPACE_VOLUME}:/workspace" \
    "${PIDOCKER_IMAGE}"
}

case "${1:-}" in
  -h|--help)
    show_help
    exit 0
    ;;
  "")
    run_container
    ;;
  *)
    echo "Unknown option: $1" >&2
    show_help >&2
    exit 2
    ;;
esac
